import speech_recognition as sr
import pyttsx3
import datetime
import webbrowser
import sys

# Initialize the Text-to-Speech (TTS) engine
try:
    engine = pyttsx3.init()
    # Optional: Voice settings (0 for male, 1 for female)
    voices = engine.getProperty('voices')
    if voices:
        engine.setProperty('voice', voices[0].id) 
    engine.setProperty('rate', 175)  # Speaking speed (wpm)
except Exception as e:
    print(f"Error initializing TTS engine: {e}")
    sys.exit(1)

def speak(text):
    """Logs the text to console and speaks it aloud."""
    print(f"Assistant: {text}")
    engine.say(text)
    engine.runAndWait()

def listen_command():
    """Captures audio from microphone and converts it to text with error handling."""
    recognizer = sr.Recognizer()
    
    with sr.Microphone() as source:
        print("\nListening...")
        # Adjust for ambient noise to make recognition clearer
        recognizer.adjust_for_ambient_noise(source, duration=1)
        # Dynamic energy threshold helps in noisy environments
        recognizer.dynamic_energy_threshold = True
        audio = recognizer.listen(source)

    try:
        print("Recognizing...")
        # Using Google Speech Recognition (Default language: English-India/US)
        query = recognizer.recognize_google(audio, language='en-in')
        print(f"User Said: {query}\n")
        return query.lower()
        
    except sr.UnknownValueError:
        # Graceful Error Handling: Speech was unintelligible
        speak("I didn't quite catch that. Could you please repeat?")
        return ""
    except sr.RequestError:
        # Graceful Error Handling: Network or API issues
        speak("Network error. Please check your internet connection.")
        return ""
    except Exception as e:
        print(f"An unexpected error occurred: {e}")
        return ""

def process_command(command):
    """Processes the validated user command and performs the action."""
    if not command:
        return True  # Keep the loop running, just skip empty commands

    # Feature: Hello Greeting
    if 'hello' in command or 'hi' in command:
        speak("Hello! I am your voice assistant. How can I help you today?")

    # Feature: Tell Time
    elif 'time' in command:
        current_time = datetime.datetime.now().strftime("%I:%M %p")
        speak(f"The current time is {current_time}")

    # Feature: Tell Date
    elif 'date' in command:
        current_date = datetime.datetime.now().strftime("%A, %B %d, %Y")
        speak(f"Today's date is {current_date}")

    # Feature: Web Search
    elif 'search' in command or 'google' in command:
        speak("What would you like me to search for?")
        search_query = listen_command()
        if search_query:
            url = f"https://www.google.com/search?q={search_query}"
            webbrowser.open(url)
            speak(f"Here are the search results for {search_query} on Google.")
        else:
            speak("Search cancelled due to missing query.")

    # Feature: Shutdown/Exit
    elif 'exit' in command or 'stop' in command or 'bye' in command:
        speak("Goodbye! Have a great day ahead.")
        return False  # Stops the program loop

    else:
        speak("I'm sorry, I don't know how to perform that action yet. Try asking for the time, date, or a web search.")
    
    return True

def main():
    """Main entry point of the application."""
    speak("System initialized successfully.")
    
    keep_running = True
    while keep_running:
        command = listen_command()
        keep_running = process_command(command)

if __name__ == "__main__":
    main()
